# Copy this file to .env.local (and add the same 4 values to your host's
# environment variables in production - e.g. Vercel Project Settings > Environment Variables)

# From Google Cloud Console > APIs & Services > Credentials > your OAuth client ID.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# One-time refresh token obtained via Google OAuth Playground while authorizing
# as the appixotech@gmail.com account with the spreadsheets scope.
GOOGLE_OAUTH_REFRESH_TOKEN=

# The long ID in your Google Sheet's URL:
# https://docs.google.com/spreadsheets/d/THIS_PART_IS_THE_ID/edit
GOOGLE_SHEET_ID=1jvj_Nxqs1zXA-OoKIfD7EhSO9NqzRB_4IIuaMa5WVvo

# Optional - defaults to Sheet1!A:D (Timestamp, Name, Email, Message)
# GOOGLE_SHEET_RANGE=Sheet1!A:D

# Optional - used by the /enquiry page's form (Start Your Project / Get a Quote).
# Defaults to Sheet1!A:I (Timestamp, Name, Email, Phone, Company, Location, Type of Inquiry, Mode, Message)
# GOOGLE_ENQUIRY_SHEET_RANGE=Sheet1!A:I
